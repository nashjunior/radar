{
  "name": "@radar/bdd",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "pretest": "pnpm --filter @radar/ingestao --filter @radar/matching --filter @radar/triagem build",
    "test": "node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js --import support/hooks.ts --import steps/ingestao.steps.ts --import steps/matching.steps.ts --import steps/triagem.steps.ts",
    "test:matching": "node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js --import support/hooks.ts --import steps/matching.steps.ts features/matching/**/*.feature",
    "test:ingestao": "node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js --import support/hooks.ts --import steps/ingestao.steps.ts features/ingestao/**/*.feature",
    "test:triagem": "node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js --import support/hooks.ts --import steps/triagem.steps.ts features/triagem/**/*.feature"
  },
  "dependencies": {
    "@radar/ingestao": "workspace:*",
    "@radar/matching": "workspace:*",
    "@radar/triagem": "workspace:*",
    "@radar/kernel": "workspace:*"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@testcontainers/postgresql": "^10.0.0",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.3",
    "testcontainers": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.2"
  }
}
