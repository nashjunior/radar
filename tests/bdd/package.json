{
  "name": "@radar/bdd",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js",
    "test:matching": "node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js features/matching/**",
    "test:ingestao": "node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber.js features/ingestao/**"
  },
  "dependencies": {
    "@radar/ingestao": "workspace:*",
    "@radar/matching": "workspace:*",
    "@radar/kernel": "workspace:*"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.2"
  }
}
