# apps/web (SPA · Vite) — variáveis de ambiente
# Copiar para .env.local. Prefixo VITE_ = exposto ao cliente (público, SEM segredos).
# A SPA nunca guarda segredo (código público); auth é via token obtido do IdP.

# URL base da API do backend (BFF)
VITE_API_URL=http://localhost:3000

# ── Cognito / Autenticação (P-08/P-91) ────────────────────────────────────────
# Usado pelo CognitoOidcGateway em produção e staging.
# Em dev, prefira VITE_DEV_AUTH_TOKEN (abaixo) se não houver User Pool configurado.

# Authority do Cognito User Pool (OIDC issuer):
# formato: https://cognito-idp.<região>.amazonaws.com/<userPoolId>
VITE_COGNITO_AUTHORITY=https://cognito-idp.sa-east-1.amazonaws.com/sa-east-1_XXXXXXXXX

# App Client ID configurado no User Pool
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# URI de retorno após login (deve estar cadastrado no App Client do Cognito)
# Em dev: http://localhost:5173
# Em prod: https://app.exemplo.com.br
VITE_COGNITO_REDIRECT_URI=http://localhost:5173

# URI após logout Hosted UI (também cadastrada no App Client do Cognito)
VITE_COGNITO_POST_LOGOUT_REDIRECT_URI=http://localhost:5173

# Escopos OIDC solicitados (padrão: openid profile email)
VITE_COGNITO_SCOPE=openid profile email

# ── Dev bypass (sem Cognito real) ──────────────────────────────────────────────
# Quando definido, o DevAuthGateway envia este valor como Bearer token estático.
# Requer que o BFF esteja rodando com AUTH_MODE=dev e AUTH_DEV_SECRET compatível (RAD-51).
#
# Formato do token: JWT HS256 assinado com AUTH_DEV_SECRET do BFF.
# Payload mínimo: { "sub": "<userId>", "custom:tenantId": "<tenantId>" }
#
# Geração em Node.js (jose) — use o mesmo AUTH_DEV_SECRET do apps/api/.env:
#   import { SignJWT } from 'jose';
#   import { createSecretKey } from 'node:crypto';
#   const key = createSecretKey(Buffer.from('<AUTH_DEV_SECRET>', 'utf-8'));
#   const token = await new SignJWT({ 'custom:tenantId': '<tenantId>' })
#     .setProtectedHeader({ alg: 'HS256' })
#     .setSubject('<userId>')
#     .setIssuedAt()
#     .setExpirationTime('8h')
#     .sign(key);
#   console.log(token);  // cole o resultado aqui
#
# NUNCA definir em produção/staging. O build/runtime do front aborta se este
# token aparecer fora dos modos development/dev/local/test.
VITE_DEV_AUTH_TOKEN=
