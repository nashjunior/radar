# apps/api — variáveis de ambiente
# Copie para .env e preencha os valores. Nunca commite .env.

# Ambiente: development | staging | production
NODE_ENV=development

# Porta HTTP do servidor BFF
PORT=3000

# PostgreSQL — nunca hardcode em código ou CI
DATABASE_URL=postgresql://radar:senha@localhost:5432/radar_dev

# ── Auth mode (P-91) ────────────────────────────────────────────────────────────
# cognito (padrão) | dev
# AUTH_MODE=dev: aceita JWT HS256 assinado com AUTH_DEV_SECRET — sem Cognito vivo.
# INVARIANTE DURO: AUTH_MODE=dev é PROIBIDO em NODE_ENV=production (processo aborta).
AUTH_MODE=cognito

# Segredo HMAC-SHA256 para tokens de dev (mínimo 32 chars recomendado).
# Obrigatório quando AUTH_MODE=dev. Nunca commite; vem de env local ou cofre de dev.
# AUTH_DEV_SECRET=

# ── Formato do token de dev (para Flávia / apps/web RAD-49 e harness E2E P-87) ──
# Header  : { "alg": "HS256", "typ": "JWT" }
# Payload : { "sub": "<userId>", "custom:tenantId": "<tenantId>" }
# Assinado com AUTH_DEV_SECRET via SignJWT (jose).
#
# Geração em Node.js (jose):
#   import { SignJWT } from 'jose';
#   import { createSecretKey } from 'node:crypto';
#   const key = createSecretKey(Buffer.from(process.env.AUTH_DEV_SECRET, 'utf-8'));
#   const token = await new SignJWT({ 'custom:tenantId': '<tenantId>' })
#     .setProtectedHeader({ alg: 'HS256' })
#     .setSubject('<userId>')
#     .setIssuedAt()
#     .setExpirationTime('8h')
#     .sign(key);
#
# O mesmo AUTH_DEV_SECRET deve ser usado no apps/web (RAD-49) e no harness E2E (P-87).

# ── Cognito / Autenticação (P-08) ──────────────────────────────────────────────
# IdP: Amazon Cognito User Pools (A08 §3). Obrigatórias em AUTH_MODE=cognito.
# O middleware valida o JWT e extrai o tenantId do claim abaixo.

# Região AWS do User Pool (padrão: sa-east-1 conforme P-28)
COGNITO_REGION=sa-east-1

# ID do User Pool (formato: <região>_<hash>, ex: sa-east-1_AbCdEfGhI)
COGNITO_USER_POOL_ID=sa-east-1_XXXXXXXXX

# ID do App Client configurado no User Pool
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Claim JWT que contém o tenantId (atributo customizado do Cognito)
# Padrão: custom:tenantId
COGNITO_TENANT_CLAIM=custom:tenantId

# ── Perfil ativo por tenant (P-90 / seam PerfilAtivoGateway) ───────────────────
# Mapa JSON: tenantId → { clienteFinalId, perfilId }
# MVP single-tenant (P-25): 1 tenantId → 1 clienteFinalId → 1 perfilId ativo.
# Provisionado junto do tenant; nunca hardcode no repositório.
# Quando o módulo Identidade & Organização existir, este var é removido e
# o adapter PerfilAtivoConfigAdapter substituído por um adapter de store.
#
# Exemplo (substitua pelos IDs reais do ambiente):
# TENANT_SEED={"meu-tenant-id":{"clienteFinalId":"uuid-cliente","perfilId":"uuid-perfil"}}
TENANT_SEED=

# ── Webhook Asaas (P-08 / P-107 (5)) ────────────────────────────────────────────
# Segredo do `asaas-access-token` (Secrets Manager com rotação). Vazio ⇒ rota
# /webhooks/pagamento recusa SEMPRE (fail-closed).
ASAAS_WEBHOOK_TOKEN=

# TRANSITÓRIA (RAD-261) — só existe durante a JANELA DE ROTAÇÃO do token acima.
# Segue sendo aceita (dupla-chave em tempo constante) para não derrubar
# notificações assinadas com o token anterior enquanto o valor novo propaga no
# Asaas. Some da task depois do passo (4) do runbook de rotação
# (infra/terraform/modules/secrets/README.md, seção "Rotação"). Vazia por
# padrão — ausência não afrouxa a checagem do token vigente.
ASAAS_WEBHOOK_TOKEN_ANTERIOR=
