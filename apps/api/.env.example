# apps/api — variáveis de ambiente
# Copie para .env e preencha os valores. Nunca commite .env.

# Ambiente: development | staging | production
NODE_ENV=development

# Porta HTTP do servidor BFF
PORT=3000

# PostgreSQL — nunca hardcode em código ou CI
DATABASE_URL=postgresql://radar:senha@localhost:5432/radar_dev

# Proxy da SPA (dev local): aponta apps/web/vite.config.ts para este servidor
# Em produção: container atrás do gateway/WAF (arquitetura/08)
# VITE_API_URL=http://localhost:3000

# Chave de criptografia (não é segredo do app — apenas example)
# KMS_KEY_ID=alias/radar-dev
